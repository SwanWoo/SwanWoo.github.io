---
import Layout from '../layouts/Layout.astro';
---

<Layout title="简历 | 武盛玮" description="武盛玮的简历 — AI Infra 开发者">
  <section class="page-header">
    <h1>简历</h1>
    <a href="mailto:swan.wu.dev@gmail.com?subject=简历索取" class="pdf-link">索取 PDF 版本</a>
  </section>

  <!-- 教育经历 -->
  <section class="section">
    <h2 class="section-title">教育经历</h2>
    <div class="timeline">
      <div class="timeline-item">
        <time>2026.09 — 2028.07</time>
        <div class="timeline-content">
          <h3>澳门科技大学</h3>
          <p class="subtitle">硕士 · 应用数学与数据科学 · 创新工程学院</p>
        </div>
      </div>
      <div class="timeline-item">
        <time>2021.09 — 2026.07</time>
        <div class="timeline-content">
          <h3>上海第二工业大学</h3>
          <p class="subtitle">本科 · 网络工程 · 计算机与信息工程学院</p>
          <p class="detail">GPA: 3.8 / 5.00</p>
          <p class="detail">核心课程：C语言程序设计、数据结构、算法设计与分析、计算机网络、操作系统、面向对象开发与设计</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 实习经历 -->
  <section class="section">
    <h2 class="section-title">实习经历</h2>
    <div class="timeline">
      <div class="timeline-item">
        <time>2026.02 — 2026.08</time>
        <div class="timeline-content">
          <h3>优刻得科技股份有限公司</h3>
          <p class="subtitle">AI Infra 实习生 · 上海</p>
          <ul>
            <li>基于 vLLM 等推理框架进行大模型推理加速与性能优化部署</li>
            <li>开发 AI Agent 应用，基于 RAG / GraphRAG 架构构建知识检索与智能问答系统</li>
            <li>参与模型推理链路端到端优化：请求调度、KV Cache 管理、批处理策略</li>
            <li>探索 GraphRAG 等新型检索增强方案，提升多跳推理与复杂关联查询能力</li>
          </ul>
        </div>
      </div>
      <div class="timeline-item">
        <time>2024.07 — 2025.01</time>
        <div class="timeline-content">
          <h3>上海泛超数字科技有限公司</h3>
          <p class="subtitle">初级系统工程师（实习）· 上海</p>
          <ul>
            <li>使用 vLLM 部署大模型推理服务，完成系统环境搭建与稳定运行保障</li>
            <li>运用 Linux 运维工具监控系统资源，分析网络流量识别异常访问模式</li>
            <li>分析网络流量数据，识别异常访问模式，预防潜在网络安全风险</li>
            <li>排查系统运行进程与可疑文件，提升系统整体安全性</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 专业技能 -->
  <section class="section">
    <h2 class="section-title">专业技能</h2>
    <div class="skills-grid">
      <div class="skill-group">
        <h3>编程语言</h3>
        <div class="skill-tags">
          <span>Python</span>
          <span>C/C++</span>
          <span>Shell</span>
          <span>JavaScript</span>
          <span>SQL</span>
        </div>
      </div>
      <div class="skill-group">
        <h3>AI / ML</h3>
        <div class="skill-tags">
          <span>vLLM</span>
          <span>LangChain</span>
          <span>LlamaIndex</span>
          <span>PyTorch</span>
          <span>RAG</span>
          <span>GraphRAG</span>
          <span>推理加速</span>
        </div>
      </div>
      <div class="skill-group">
        <h3>Web 开发</h3>
        <div class="skill-tags">
          <span>FastAPI</span>
          <span>Vue.js</span>
          <span>WebSocket</span>
          <span>HTMX</span>
        </div>
      </div>
      <div class="skill-group">
        <h3>系统与运维</h3>
        <div class="skill-tags">
          <span>Linux</span>
          <span>Docker</span>
          <span>Nginx</span>
          <span>Git</span>
          <span>systemd</span>
        </div>
      </div>
      <div class="skill-group">
        <h3>数据库</h3>
        <div class="skill-tags">
          <span>PostgreSQL</span>
          <span>MySQL</span>
          <span>MongoDB</span>
          <span>Redis</span>
          <span>Qdrant</span>
        </div>
      </div>
      <div class="skill-group">
        <h3>网络工程</h3>
        <div class="skill-tags">
          <span>ISIS</span>
          <span>OSPF</span>
          <span>BGP</span>
          <span>L3VPN</span>
          <span>L2VPN</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 荣誉奖项 -->
  <section class="section">
    <h2 class="section-title">荣誉奖项</h2>
    <ul class="awards-list">
      <li>
        <span class="award-badge">🥈</span>
        <div>
          <strong>校级二等奖学金</strong>（专业前 10%）
          <span class="award-org">— 上海第二工业大学</span>
        </div>
      </li>
      <li>
        <span class="award-badge">🥈</span>
        <div><strong>ASC 世界大学生超级计算机竞赛二等奖</strong></div>
      </li>
      <li>
        <span class="award-badge">🥉</span>
        <div><strong>蓝桥杯市三等奖</strong></div>
      </li>
      <li>
        <span class="award-badge">🥉</span>
        <div><strong>数学建模竞赛三等奖</strong></div>
      </li>
    </ul>
  </section>
</Layout>

<style>
  .page-header {
    padding: 3.5rem 0 1.25rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .page-header h1 {
    font-size: 1.6rem;
    font-weight: 400;
    letter-spacing: 0.1em;
  }

  .pdf-link {
    color: var(--accent);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    transition: opacity 0.25s;
  }

  .pdf-link:hover {
    opacity: 0.6;
  }

  .section {
    padding: 2.25rem 0;
    border-top: 1px solid var(--border);
  }

  .section-title {
    font-size: 1.05rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 13rem 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  time {
    font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    font-size: 0.78rem;
    color: var(--text-dim);
    white-space: nowrap;
    padding-top: 0.2rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }

  .timeline-content h3 {
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    margin-bottom: 0.2rem;
  }

  .subtitle {
    color: var(--accent);
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
  }

  .detail {
    color: var(--text-dim);
    font-size: 0.82rem;
    margin-bottom: 0.2rem;
    line-height: 1.6;
  }

  .timeline-content ul {
    margin-top: 0.6rem;
    padding-left: 1.25rem;
    color: var(--text-dim);
    font-size: 0.85rem;
  }

  .timeline-content li {
    margin-bottom: 0.4rem;
    line-height: 1.7;
  }

  /* Skills */
  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skill-group h3 {
    font-size: 0.82rem;
    font-weight: 400;
    color: var(--text);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill-tags span {
    font-size: 0.75rem;
    padding: 0.2rem 0.65rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text-dim);
    letter-spacing: 0.03em;
    transition: border-color 0.25s, color 0.25s;
  }

  .skill-tags span:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Awards */
  .awards-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .awards-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.88rem;
  }

  .award-badge {
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .awards-list strong {
    color: var(--text);
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .award-org {
    color: var(--text-dim);
    font-size: 0.8rem;
  }

  @media (max-width: 640px) {
    .timeline-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    time {
      padding-top: 0;
    }
  }
</style>
