---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const projects = (await getCollection('portfolio', ({ data }) => !data.draft))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);
---

<Layout title="武盛玮" description="AI Infra · 推理加速 · RAG — 武盛玮的个人主页">
  <!-- Hero -->
  <section class="hero">
    <img src="/avatar.jpg" alt="武盛玮" class="avatar" width="120" height="120" />
    <h1 class="name">武盛玮</h1>
    <p class="name-en">Swan Woo</p>
    <p class="tagline">AI Infra · 推理加速 · RAG</p>
    <div class="divider"></div>
    <p class="bio">
      在优刻得（UCloud）从事大模型推理加速与 AI Agent 开发。<br />
      即将就读澳门科技大学创新工程学院，攻读应用数学与数据科学硕士。
    </p>
    <div class="hero-links">
      <a href="mailto:swan.wu.dev@gmail.com">Email</a>
      <span class="link-sep">·</span>
      <a href="https://github.com/SwanWoo" target="_blank" rel="noopener">GitHub</a>
      <span class="link-sep">·</span>
      <span class="location">上海</span>
    </div>
  </section>

  <!-- Blog -->
  <section class="section">
    <div class="section-header">
      <h2>最新文章</h2>
      <a href="/blog" class="see-all">全部 →</a>
    </div>
    {posts.length === 0 ? (
      <p class="empty">暂无文章。</p>
    ) : (
      <ul class="entry-list">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.slug}/`} class="entry-link">
              <time>{new Date(post.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'short' })}</time>
              <span class="entry-title">{post.data.title}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <!-- Education -->
  <section class="section">
    <div class="section-header">
      <h2>教育经历</h2>
      <a href="/cv" class="see-all">完整简历 →</a>
    </div>
    <ul class="entry-list">
      <li>
        <div class="entry-row">
          <time>2026 — 2028</time>
          <div>
            <div class="entry-title">澳门科技大学</div>
            <div class="entry-sub">硕士 · 应用数学与数据科学</div>
          </div>
        </div>
      </li>
      <li>
        <div class="entry-row">
          <time>2021 — 2026</time>
          <div>
            <div class="entry-title">上海第二工业大学</div>
            <div class="entry-sub">本科 · 网络工程</div>
          </div>
        </div>
      </li>
    </ul>
  </section>

  <!-- Experience -->
  <section class="section">
    <div class="section-header">
      <h2>实习经历</h2>
    </div>
    <ul class="entry-list">
      <li>
        <div class="entry-row">
          <time>2026.02 — 08</time>
          <div>
            <div class="entry-title">优刻得科技股份有限公司</div>
            <div class="entry-sub">AI Infra 实习生 · 上海</div>
          </div>
        </div>
      </li>
      <li>
        <div class="entry-row">
          <time>2024.07 — 2025.01</time>
          <div>
            <div class="entry-title">上海泛超数字科技有限公司</div>
            <div class="entry-sub">初级系统工程师（实习）· 上海</div>
          </div>
        </div>
      </li>
    </ul>
  </section>

  <!-- Projects -->
  <section class="section">
    <div class="section-header">
      <h2>项目</h2>
      <a href="/portfolio" class="see-all">查看全部 →</a>
    </div>
    <ul class="entry-list">
      {projects.map((project) => (
        <li>
          <a href={`/portfolio/${project.slug}/`} class="entry-link">
            <span class="project-tag">{project.data.tags?.[0] ?? ''}</span>
            <span class="entry-title">{project.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- Contact -->
  <section class="section contact">
    <div class="contact-divider"></div>
    <p class="contact-text">
      有合作意向或想交流技术，欢迎联系我。
    </p>
    <div class="contact-links">
      <a href="mailto:swan.wu.dev@gmail.com">swan.wu.dev@gmail.com</a>
      <a href="https://github.com/SwanWoo" target="_blank" rel="noopener">github.com/SwanWoo</a>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4.5rem 0 3rem;
  }

  .avatar {
    width: 120px;
    height: 120px;
    border-radius: 12px;
    object-fit: cover;
    margin-bottom: 2rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
    transition: transform 0.4s ease;
  }

  .avatar:hover {
    transform: scale(1.03);
  }

  .name {
    font-family: 'Source Serif 4', 'Noto Serif SC', 'Songti SC', Georgia, serif;
    font-size: 2rem;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.2em;
    color: var(--text);
    margin: 0;
  }

  .name-en {
    font-size: 0.88rem;
    font-style: italic;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    margin-top: 0.4rem;
    margin-bottom: 1.25rem;
  }

  .tagline {
    color: var(--accent);
    font-size: 0.92rem;
    letter-spacing: 0.12em;
    margin-bottom: 1.75rem;
  }

  .divider {
    width: 48px;
    height: 1px;
    background: var(--border);
    margin-bottom: 1.75rem;
  }

  .bio {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--text-dim);
    max-width: 460px;
    margin-bottom: 1.5rem;
  }

  .hero-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  .hero-links a {
    color: var(--text-dim);
    letter-spacing: 0.04em;
    transition: color 0.25s;
  }

  .hero-links a:hover {
    color: var(--accent);
  }

  .link-sep {
    color: var(--border);
    font-size: 0.6rem;
  }

  .location {
    color: var(--text-dim);
    font-size: 0.85rem;
  }

  /* ── Sections ── */
  .section {
    padding: 2.75rem 0;
    border-top: 1px solid var(--border);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    font-size: 1.05rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--text);
  }

  .see-all {
    color: var(--text-dim);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    transition: color 0.25s;
  }

  .see-all:hover {
    color: var(--accent);
  }

  /* ── Entry list ── */
  .entry-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .entry-list li {
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--border);
  }

  .entry-list li:last-child {
    border-bottom: none;
  }

  .entry-link {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    color: var(--text);
    transition: opacity 0.3s ease;
  }

  .entry-link:hover {
    opacity: 0.55;
  }

  .entry-row {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
  }

  time {
    font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    font-size: 0.78rem;
    color: var(--text-dim);
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 90px;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }

  .entry-title {
    font-size: 0.95rem;
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  .entry-sub {
    color: var(--text-dim);
    font-size: 0.82rem;
    margin-top: 0.2rem;
    letter-spacing: 0.02em;
  }

  .project-tag {
    font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    font-size: 0.68rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    flex-shrink: 0;
    min-width: 56px;
  }

  .empty {
    color: var(--text-dim);
    font-size: 0.88rem;
    padding: 1rem 0;
  }

  /* ── Contact ── */
  .contact {
    border-top: none;
    text-align: center;
    padding: 3.5rem 0 2rem;
  }

  .contact-divider {
    width: 48px;
    height: 1px;
    background: var(--border);
    margin: 0 auto 2rem;
  }

  .contact-text {
    color: var(--text-dim);
    font-size: 0.88rem;
    font-style: italic;
    margin-bottom: 1.25rem;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .contact-links a {
    color: var(--accent);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    transition: opacity 0.25s;
  }

  .contact-links a:hover {
    opacity: 0.6;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .hero {
      padding: 3rem 0 2rem;
    }

    .avatar {
      width: 96px;
      height: 96px;
    }

    .name {
      font-size: 1.6rem;
    }

    .entry-row {
      flex-direction: column;
      gap: 0.15rem;
    }

    .entry-link {
      flex-direction: column;
      gap: 0.15rem;
    }

    time {
      min-width: auto;
    }

    .section {
      padding: 2rem 0;
    }
  }
</style>
