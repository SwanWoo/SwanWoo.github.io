---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const projects = (await getCollection('portfolio', ({ data }) => !data.draft))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);
---

<Layout title="武盛玮">
  <!-- About -->
  <section class="about">
    <img src="/avatar.jpg" alt="武盛玮" class="avatar" width="72" height="72" />
    <div class="about-text">
      <h1>武盛玮 <span class="name-en">(Swan Woo)</span></h1>
      <p class="bio">Python & C++ 开发者 · AI Infra · 推理加速 · RAG</p>
      <p class="desc">
        在优刻得（UCloud）从事大模型推理加速与 AI Agent 开发。
        即将就读澳门科技大学创新工程学院，攻读应用数学与数据科学硕士。
      </p>
      <p class="location">📍 上海，中国</p>
      <div class="social">
        <a href="mailto:swan.wu.dev@gmail.com">Email</a>
        <a href="https://github.com/SwanWoo" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section class="section">
    <div class="section-header">
      <h2>最新文章</h2>
      <a href="/blog" class="see-all">全部 →</a>
    </div>
    {posts.length === 0 ? (
      <p class="empty">暂无文章。</p>
    ) : (
      <ul class="entry-list">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.slug}/`} class="entry-link">
              <time>{new Date(post.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'short' })}</time>
              <span class="entry-title">{post.data.title}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <!-- Education -->
  <section class="section">
    <div class="section-header">
      <h2>教育经历</h2>
      <a href="/cv" class="see-all">完整简历 →</a>
    </div>
    <ul class="entry-list">
      <li>
        <div class="entry-row">
          <time>2026.09 — 2028.07</time>
          <div>
            <div class="entry-title">澳门科技大学</div>
            <div class="entry-sub">硕士 · 应用数学与数据科学 · 创新工程学院</div>
          </div>
        </div>
      </li>
      <li>
        <div class="entry-row">
          <time>2021.09 — 2026.07</time>
          <div>
            <div class="entry-title">上海第二工业大学</div>
            <div class="entry-sub">本科 · 网络工程 · 计算机与信息工程学院</div>
          </div>
        </div>
      </li>
    </ul>
  </section>

  <!-- Experience -->
  <section class="section">
    <div class="section-header">
      <h2>实习经历</h2>
    </div>
    <ul class="entry-list">
      <li>
        <div class="entry-row">
          <time>2026.02 — 2026.08</time>
          <div>
            <div class="entry-title">优刻得科技股份有限公司</div>
            <div class="entry-sub">AI Infra 实习生 · 上海</div>
          </div>
        </div>
      </li>
      <li>
        <div class="entry-row">
          <time>2024.07 — 2025.01</time>
          <div>
            <div class="entry-title">上海泛超数字科技有限公司</div>
            <div class="entry-sub">初级系统工程师（实习）· 上海</div>
          </div>
        </div>
      </li>
    </ul>
  </section>

  <!-- Projects -->
  <section class="section">
    <div class="section-header">
      <h2>项目</h2>
      <a href="/portfolio" class="see-all">查看全部 →</a>
    </div>
    <ul class="entry-list">
      {projects.map((project) => (
        <li>
          <a href={`/portfolio/${project.slug}/`} class="entry-link">
            <span class="project-tag">{project.data.tags?.[0] ?? ''}</span>
            <span class="entry-title">{project.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- Contact -->
  <section class="section contact">
    <h2>联系方式</h2>
    <p class="contact-desc">
      有合作意向或想交流技术，欢迎通过以下方式联系我。
    </p>
    <div class="contact-links">
      <a href="mailto:swan.wu.dev@gmail.com">swan.wu.dev@gmail.com</a>
      <a href="https://github.com/SwanWoo" target="_blank" rel="noopener">github.com/SwanWoo</a>
    </div>
  </section>
</Layout>

<style>
  /* About */
  .about {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 3.5rem 0 2rem;
  }

  .avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 2px solid var(--border);
  }

  .about-text h1 {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .name-en {
    color: var(--text-dim);
    font-weight: 400;
    font-size: 0.85em;
  }

  .bio {
    color: var(--accent);
    font-size: 0.88rem;
    margin: 0.15rem 0 0.5rem;
  }

  .desc {
    color: var(--text-dim);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .location {
    color: var(--text-dim);
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }

  .social {
    display: flex;
    gap: 1rem;
    margin-top: 0.75rem;
  }

  .social a {
    color: var(--accent);
    font-size: 0.85rem;
    transition: opacity 0.2s;
  }

  .social a:hover {
    opacity: 0.7;
  }

  /* Sections */
  .section {
    padding: 2.5rem 0;
    border-top: 1px solid var(--border);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.25rem;
  }

  .section-header h2 {
    font-size: 1.15rem;
    font-weight: 700;
  }

  .see-all {
    color: var(--accent);
    font-size: 0.85rem;
    transition: opacity 0.2s;
  }

  .see-all:hover {
    opacity: 0.7;
  }

  /* Entry list */
  .entry-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .entry-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
  }

  .entry-list li:last-child {
    border-bottom: none;
  }

  .entry-link {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    color: var(--text);
    transition: color 0.2s;
  }

  .entry-link:hover {
    color: var(--accent);
  }

  .entry-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  time {
    font-size: 0.8rem;
    color: var(--text-dim);
    white-space: nowrap;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
    min-width: 90px;
  }

  .entry-title {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .entry-sub {
    color: var(--text-dim);
    font-size: 0.85rem;
    margin-top: 0.15rem;
  }

  .project-tag {
    font-size: 0.72rem;
    color: var(--accent);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    min-width: 60px;
  }

  .empty {
    color: var(--text-dim);
    font-size: 0.9rem;
    padding: 1rem 0;
  }

  /* Contact */
  .contact {
    border-top: 1px solid var(--border);
    padding: 2.5rem 0;
  }

  .contact h2 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .contact-desc {
    color: var(--text-dim);
    font-size: 0.92rem;
    margin-bottom: 1rem;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .contact-links a {
    color: var(--accent);
    font-size: 0.88rem;
    transition: opacity 0.2s;
  }

  .contact-links a:hover {
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .about {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 2.5rem 0 1.5rem;
    }

    .social {
      justify-content: center;
    }

    .entry-row {
      flex-direction: column;
      gap: 0.2rem;
    }

    .entry-link {
      flex-direction: column;
      gap: 0.2rem;
    }

    time {
      min-width: auto;
    }
  }
</style>
