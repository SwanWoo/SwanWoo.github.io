---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('portfolio', ({ data }) => !data.draft);
const sorted = projects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout title="项目 | 武盛玮" description="武盛玮的个人项目作品集 — AI Infra、RAG、全栈开发">
  <section class="page-header">
    <h1>项目</h1>
    <p>涵盖 AI Infra、RAG 系统、量化交易、全栈开发等方向的个人与团队项目。</p>
  </section>

  <ul class="entry-list">
    {sorted.map((project) => (
      <li>
        <a href={`/portfolio/${project.slug}/`} class="entry-link">
          <span class="project-tag">{project.data.tags?.[0] ?? ''}</span>
          <div class="project-info">
            <span class="entry-title">{project.data.title}</span>
            <span class="entry-desc">{project.data.description}</span>
          </div>
        </a>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .page-header {
    padding: 3.5rem 0 1.75rem;
  }

  .page-header h1 {
    font-size: 1.6rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    margin-bottom: 0.4rem;
  }

  .page-header p {
    color: var(--text-dim);
    font-size: 0.88rem;
    font-style: italic;
  }

  .entry-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .entry-list li {
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .entry-list li:last-child {
    border-bottom: none;
  }

  .entry-link {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    color: var(--text);
    transition: opacity 0.3s ease;
  }

  .entry-link:hover {
    opacity: 0.55;
  }

  .project-tag {
    font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    font-size: 0.68rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    flex-shrink: 0;
    min-width: 70px;
    padding-top: 0.2rem;
  }

  .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .entry-title {
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  .entry-desc {
    color: var(--text-dim);
    font-size: 0.82rem;
    line-height: 1.6;
    letter-spacing: 0.02em;
  }

  @media (max-width: 640px) {
    .entry-link {
      flex-direction: column;
      gap: 0.25rem;
    }
    .project-tag { min-width: auto; }
  }
</style>
