---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('portfolio', ({ data }) => !data.draft);
const sorted = projects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout title="项目 | 武盛玮" description="武盛玮的个人项目作品集 — AI Infra、RAG、全栈开发">
  <section class="page-header">
    <h1>项目</h1>
    <p>涵盖 AI Infra、RAG 系统、量化交易、全栈开发等方向的个人与团队项目。</p>
  </section>

  <ul class="entry-list">
    {sorted.map((project) => (
      <li>
        <a href={`/portfolio/${project.slug}/`} class="entry-link">
          <span class="project-tag">{project.data.tags?.[0] ?? ''}</span>
          <div class="project-info">
            <span class="entry-title">{project.data.title}</span>
            <span class="entry-desc">{project.data.description}</span>
          </div>
        </a>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .page-header {
    padding: 3rem 0 1.5rem;
  }

  .page-header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }

  .page-header p {
    color: var(--text-dim);
    font-size: 0.92rem;
  }

  .entry-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .entry-list li {
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .entry-list li:last-child {
    border-bottom: none;
  }

  .entry-link {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    color: var(--text);
    transition: color 0.2s;
  }

  .entry-link:hover {
    color: var(--accent);
  }

  .project-tag {
    font-size: 0.72rem;
    color: var(--accent);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    min-width: 70px;
    padding-top: 0.15rem;
  }

  .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .entry-title {
    font-size: 1rem;
    font-weight: 600;
  }

  .entry-desc {
    color: var(--text-dim);
    font-size: 0.85rem;
    line-height: 1.55;
  }

  @media (max-width: 640px) {
    .entry-link {
      flex-direction: column;
      gap: 0.25rem;
    }
    .project-tag { min-width: auto; }
  }
</style>
