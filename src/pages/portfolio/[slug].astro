---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('portfolio');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<Layout title={`${project.data.title} | 武盛玮`} description={project.data.description}>
  <article class="project">
    <a href="/portfolio" class="back">← 项目</a>
    <header>
      <h1>{project.data.title}</h1>
      <p class="subtitle">{project.data.description}</p>
      {project.data.tags && (
        <div class="tags">
          {project.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="content">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .project {
    padding: 3rem 0 2rem;
  }

  .back {
    display: inline-block;
    color: var(--text-dim);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    margin-bottom: 1.75rem;
    transition: opacity 0.25s;
  }

  .back:hover {
    opacity: 0.55;
  }

  header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--border);
  }

  h1 {
    font-size: 1.6rem;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: 0.06em;
    margin-bottom: 0.6rem;
  }

  .subtitle {
    color: var(--text-dim);
    font-size: 0.92rem;
    margin-bottom: 0.75rem;
    line-height: 1.7;
    font-style: italic;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-size: 0.68rem;
    padding: 0.18rem 0.55rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  .content {
    line-height: 1.9;
    font-size: 0.95rem;
  }

  .content :global(h2) {
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }

  .content :global(h3) {
    font-size: 1.05rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    margin: 2rem 0 0.75rem;
    color: var(--text);
  }

  .content :global(h4) {
    font-size: 0.95rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    margin: 1.75rem 0 0.6rem;
    color: var(--text);
  }

  .content :global(h5), .content :global(h6) {
    font-size: 0.88rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    margin: 1.5rem 0 0.5rem;
    color: var(--text-dim);
  }

  .content :global(hr) {
    border: none;
    height: 1px;
    background: var(--border);
    margin: 2.5rem 0;
  }

  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.88rem;
  }

  .content :global(thead) {
    border-bottom: 2px solid var(--border);
  }

  .content :global(th) {
    text-align: left;
    padding: 0.6rem 0.75rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--text);
  }

  .content :global(td) {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-dim);
  }

  .content :global(tbody tr:hover) {
    background: var(--surface);
  }

  .content :global(p) {
    margin-bottom: 1.25rem;
    color: var(--text-dim);
    line-height: 1.9;
  }

  .content :global(ul), .content :global(ol) {
    margin: 0.75rem 0 1.5rem 1.5rem;
    color: var(--text-dim);
  }

  .content :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.8;
  }

  .content :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .content :global(em) {
    font-style: italic;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--accent);
    margin: 1.25rem 0;
    padding: 0.75rem 1.25rem;
    background: var(--surface);
    color: var(--text-dim);
    font-style: italic;
  }

  .content :global(code) {
    background: var(--code-bg);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    font-size: 0.85em;
    color: var(--code-text);
    font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  }

  .content :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
    color: var(--text);
    font-size: 0.82rem;
    line-height: 1.7;
  }

  .content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.25s;
  }

  .content :global(a:hover) {
    opacity: 0.7;
  }

  .content :global(img) {
    max-width: 100%;
    border-radius: var(--radius);
    margin: 1.5rem 0;
  }
</style>
