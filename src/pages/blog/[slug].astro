---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title}>
  <article class="blog-post">
    <a href="/blog" class="back-link">← 返回博客</a>
    <header>
      <time>
        {new Date(post.data.date).toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
      <h1>{post.data.title}</h1>
      {post.data.tags && (
        <div class="tags">
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="content">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .blog-post {
    padding: 3rem 0 2rem;
    max-width: 720px;
  }

  .back-link {
    display: inline-block;
    color: var(--text-dim);
    font-size: 0.88rem;
    margin-bottom: 1.5rem;
  }
  .back-link:hover { color: var(--accent); }

  header {
    margin-bottom: 2.5rem;
  }

  header time {
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  h1 {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.3;
    margin: 0.5rem 0 1rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.65rem;
    background: rgba(56, 189, 248, 0.08);
    color: var(--accent);
    border-radius: 100px;
    font-weight: 500;
  }

  .content {
    line-height: 1.85;
  }

  .content :global(h2) {
    font-size: 1.3rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
  }

  .content :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }

  .content :global(p) {
    margin-bottom: 1rem;
    color: var(--text-dim);
  }

  .content :global(ul), .content :global(ol) {
    margin: 0.75rem 0 1.25rem 1.5rem;
    color: var(--text-dim);
  }

  .content :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.7;
  }

  .content :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .content :global(code) {
    background: rgba(56, 189, 248, 0.08);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.88em;
    color: var(--accent);
  }

  .content :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.25rem 0;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
    color: var(--text);
    font-size: 0.88rem;
  }
</style>
