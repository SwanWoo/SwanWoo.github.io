---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="博客" description="武盛玮的技术博客 — AI Infra、大模型应用、全栈开发">
  <section class="page-header">
    <h1>博客</h1>
    <p>技术笔记、项目复盘与学习心得。</p>
  </section>

  {sorted.length === 0 ? (
    <p class="empty">暂无文章，敬请期待。</p>
  ) : (
    <div class="post-list">
      {sorted.map((post) => (
        <a href={`/blog/${post.slug}/`} class="post-card">
          <time>{new Date(post.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          <h2>{post.data.title}</h2>
          {post.data.tags && (
            <div class="post-tags">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  )}
</Layout>

<style>
  .page-header {
    padding: 3.5rem 0 2rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: var(--text-dim);
    font-size: 1rem;
  }

  .empty {
    color: var(--text-dim);
    text-align: center;
    padding: 3rem 0;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-bottom: 2rem;
  }

  .post-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: border-color 0.2s, transform 0.2s;
    color: var(--text);
  }

  .post-card:hover {
    opacity: 1;
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .post-card time {
    font-size: 0.8rem;
    color: var(--text-dim);
    font-variant-numeric: tabular-nums;
  }

  .post-card h2 {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0.35rem 0 0.5rem;
    line-height: 1.35;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-size: 0.72rem;
    padding: 0.2rem 0.55rem;
    background: rgba(56, 189, 248, 0.08);
    color: var(--accent);
    border-radius: 100px;
    font-weight: 500;
  }
</style>
