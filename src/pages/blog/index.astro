---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="博客 | 武盛玮" description="武盛玮的技术博客 — AI Infra、大模型应用、全栈开发">
  <section class="page-header">
    <h1>博客</h1>
    <p>技术笔记、项目复盘与学习心得。</p>
  </section>

  {sorted.length === 0 ? (
    <p class="empty">暂无文章，敬请期待。</p>
  ) : (
    <ul class="entry-list">
      {sorted.map((post) => (
        <li>
          <a href={`/blog/${post.slug}/`} class="entry-link">
            <time>{new Date(post.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'short' })}</time>
            <span class="entry-title">{post.data.title}</span>
            {post.data.tags && (
              <div class="entry-tags">
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </a>
        </li>
      ))}
    </ul>
  )}
</Layout>

<style>
  .page-header {
    padding: 3.5rem 0 1.75rem;
  }

  .page-header h1 {
    font-size: 1.6rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    margin-bottom: 0.4rem;
  }

  .page-header p {
    color: var(--text-dim);
    font-size: 0.88rem;
    font-style: italic;
  }

  .empty {
    color: var(--text-dim);
    text-align: center;
    padding: 3rem 0;
    font-style: italic;
  }

  .entry-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .entry-list li {
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--border);
  }

  .entry-list li:last-child {
    border-bottom: none;
  }

  .entry-link {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    color: var(--text);
    transition: opacity 0.3s ease;
    flex-wrap: wrap;
  }

  .entry-link:hover {
    opacity: 0.55;
  }

  time {
    font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    font-size: 0.78rem;
    color: var(--text-dim);
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 80px;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }

  .entry-title {
    font-size: 0.95rem;
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  .entry-tags {
    display: flex;
    gap: 0.3rem;
    margin-left: auto;
  }

  .tag {
    font-size: 0.68rem;
    padding: 0.15rem 0.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  @media (max-width: 640px) {
    .entry-link {
      flex-direction: column;
      gap: 0.2rem;
    }
    time { min-width: auto; }
    .entry-tags { margin-left: 0; }
  }
</style>
