---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '武盛玮的个人技术博客与作品集 — Python & C++ 开发者 / AI Infra 推理加速' } = Astro.props;

const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: '首页' },
  { href: '/portfolio', label: '项目展示' },
  { href: '/cv', label: '简历' },
  { href: '/blog', label: '博客' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="武盛玮" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title === '武盛玮 | SwanWoo' ? title : `${title} | 武盛玮`}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">SwanWoo</a>
        <div class="nav-links">
          {navItems.map((item) => (
            <a href={item.href} class:list={[{ active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}>
              {item.label}
            </a>
          ))}
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-content">
        <div class="footer-links">
          <a href="mailto:swan.wu.dev@gmail.com">📧 Email</a>
          <a href="https://github.com/SwanWoo" target="_blank" rel="noopener">🐙 GitHub</a>
        </div>
        <p class="footer-copy">© {new Date().getFullYear()} 武盛玮 · Built with Astro</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0a0a0f;
    --surface: #12121a;
    --surface-hover: #1a1a28;
    --border: #1e1e30;
    --text: #e4e4ed;
    --text-dim: #8888a0;
    --accent: #38bdf8;
    --accent-dim: #0ea5e9;
    --gradient-from: #38bdf8;
    --gradient-to: #a78bfa;
    --radius: 10px;
    --max-w: 960px;
    --header-h: 64px;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  a { color: var(--accent); text-decoration: none; transition: opacity 0.2s; }
  a:hover { opacity: 0.8; }

  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 15, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    height: var(--header-h);
  }

  nav {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: var(--header-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--text);
    background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .logo:hover { opacity: 1; }

  .nav-links { display: flex; gap: 1.5rem; }
  .nav-links a {
    color: var(--text-dim);
    font-size: 0.88rem;
    font-weight: 500;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .nav-links a:hover, .nav-links a.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
    opacity: 1;
  }

  main {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
    min-height: calc(100vh - var(--header-h) - 140px);
  }

  footer {
    border-top: 1px solid var(--border);
    margin-top: 5rem;
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .footer-content { max-width: var(--max-w); margin: 0 auto; }
  .footer-links { display: flex; gap: 1.5rem; justify-content: center; margin-bottom: 0.75rem; }
  .footer-links a { color: var(--text-dim); font-size: 0.88rem; }
  .footer-copy { color: var(--text-dim); font-size: 0.8rem; opacity: 0.7; }

  @media (max-width: 640px) {
    .nav-links { gap: 1rem; }
    .nav-links a { font-size: 0.82rem; }
  }
</style>
